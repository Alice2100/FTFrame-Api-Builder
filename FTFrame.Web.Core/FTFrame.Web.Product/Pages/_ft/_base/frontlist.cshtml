@page
@using FTFrame;
@using FTFrame.Tool;
@using FTFrame.Project.Core
@using FTFrame.DBClient;
@using Microsoft.AspNetCore.Http.Extensions;
@{Layout = null;}
@{if (!ProjectFilter.Page(HttpContext)) return;}
@{ if (!FTFrame.Server.Core.AccessControl.Accessed(HttpContext, 0, "", 0, 0, "", 0, 0, "", 0, "")) { Output.Write(FTFrame.Server.Core.AccessControl.AccesseInfo(0, "", 0, "")); return; }}
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
@{ FTFrame.Server.Core.JsCss.GetAppend(HttpContext); }
<!doctype html>
<html lang='en'>
  <head>
  <meta charset='UTF-8'>
  <link rel='stylesheet' href='../_front/lib/element-ui/index.css'>
    <script src='../_front/lib/vue.js'></script>
	<script src='../_front/lib/httpVueLoader.js'></script>
	<script src='../_front/lib/element-ui/index.js'></script>
	<script src='../_front/lib/axios.min.js'></script>
	@*<script src='../_front/lib/config.js'></script>
	<script src='../_front/lib/base.js'></script>*@
	<title>Front Components</title>
  </head>
<body>
<div id="app1">
<el-row :gutter="20">
<el-col :span="6">
    <el-menu
      default-active="2"
      class="el-menu-vertical-demo"
      @("@")open="handleOpen"
      @("@")close="handleClose"
      background-color="#545c64"
      text-color="#fff"
      active-text-color="#ffd04b">
	  @Html.Raw(FTFrame.Server.Core.Front.FrontListMenu())
    </el-menu>
  </el-col>
<el-col :span="18">
<iframe :src="para.src" style="width: 100%;height: 100%" frameborder="0" id="bdIframe"></iframe>
</el-col>
</el-row>
</div>
<script type='text/javascript'>

</script>
<script>
var Main = {
	data: function() {
        return {
         para:{src:"about:blank",}
        }
    },
	methods: {
      handleOpen(key, keyPath) {
        console.log(key, keyPath);
      },
      handleClose(key, keyPath) {
        console.log(key, keyPath);
      },
	  changeurl(name)
	  {
		  this.$set(this.para,'src',"/_ft/_front/"+name+"_test.html?rdn="+(new Date()).valueOf());
		  },
	  dropdownCmd(command){
		  if(command==null)return;
          var cmds=command.split('|');
		  if(cmds[0]=='delete'){
			this.$confirm('This operation will delete the file. Do you want to continue?', 'Prompt', {
          confirmButtonText: 'OK',
          cancelButtonText: 'Cancel',
          type: 'warning'
        }).then(() => {

axios({
		url:'/_ftfront/delete',
		method: 'post',
		data:{type: cmds[1],comName: cmds[2]},
		transformRequest: [
      function (data) {
         let ret = ''
         for (let it in data) {
            ret += encodeURIComponent(it) + '=' + encodeURIComponent(data[it]) + '&'
         }
         ret = ret.substring(0, ret.lastIndexOf('&'));
         return ret
      }
    ],
    headers: {
       'Content-Type': 'application/x-www-form-urlencoded'
    }
	}).then(res=>{this.$message({type: 'success',message: 'Delete successful!'});location.reload();
				})
        });
		}
		else if(cmds[0]=='download1'){
			location.href="/_ftfront/download?type=1&comName="+cmds[2];
		}
		else if(cmds[0]=='download2'){
			location.href="/_ftfront/download?type=2&comName="+cmds[2];
		}
	  },
    },
	mounted(){
    const oIframe = document.getElementById('bdIframe');
    //const deviceWidth = document.documentElement.clientWidth;
    const deviceHeight = document.documentElement.clientHeight;
    //oIframe.style.width = (Number(deviceWidth)-220) + 'px'; //
    oIframe.style.height = (Number(deviceHeight)-20) + 'px'; //
  },
};
var Ctor = Vue.extend(Main);
new Ctor().$mount('#app1');
</script>
</body>
</html>