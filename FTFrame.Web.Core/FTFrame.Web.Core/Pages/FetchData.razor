@page "/fetchdata"
@using Project.QC.Test;
@inject UserInfoService _UserInfoService

<h1>Users List</h1>

<p>This component demonstrates fetching data from a service.</p>

@if (users == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>FID</th>
                <th>Name</th>
                <th>AddTime</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@user.Fid</td>
                    <td>@user.Name</td>
                    <td>@user.Addtime.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    List<UserInfo> users;
    protected override void OnAfterRender()
    {
    }

    protected override async Task OnInitAsync()
    {
        users = await _UserInfoService.GetUserInfosAsync();
    }
}
